@article{Morgan2018a,
  title = {Development of a {{Rigorous Modeling Framework}} for {{Solvent-Based CO2 Capture}}. {{Part}} 2: {{Steady-State Validation}} and {{Uncertainty Quantification}} with {{Pilot Plant Data}}},
  author = {Morgan, Joshua C. and Soares Chinen, Anderson and Omell, Benjamin and Bhattacharyya, Debangsu and Tong, Charles and Miller, David C. and Buschle, Bill and Lucquiaud, Mathieu},
  year = 2018,
