      \field{journaltitle}{Industrial and Engineering Chemistry Research}
      \field{title}{Predicting {{Thermodynamic Properties}} of {{Ions}} in {{Single Solvents}} and in {{Mixed Solvents Using}} a {{Modified Born Term}} within the {{ePC-SAFT Framework}}}
